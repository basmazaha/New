---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils.ts';
import { createClient } from '@supabase/supabase-js';

const t = useTranslations(Astro.currentLocale ?? 'ar');

const { token } = Astro.params;

if (!token) {
  return Astro.redirect('/404');
}

const { locals } = Astro;
const env = locals.runtime.env;

const supabaseUrl    = env.PUBLIC_SUPABASE_URL || env.SUPABASE_URL;
const serviceRoleKey = env.SUPABASE_SERVICE_ROLE_KEY;

if (!supabaseUrl || !serviceRoleKey) {
  console.error('Missing Supabase configuration in environment variables');
  return Astro.redirect('/error?msg=server-config');
}

const supabase = createClient(
  supabaseUrl,
  serviceRoleKey,
  {
    auth: {
      autoRefreshToken: false,
      persistSession: false,
      detectSessionInUrl: false
    }
  }
);

let booking = null;
let pageError = null;

const { data, error } = await supabase
  .from('appointments')
  .select('id, full_name, email, date_time, reason, status')
  .eq('manage_token', token)
  .single();

if (error || !data) {
  pageError = t('reschedule.invalid_link');
} 
else if (data.status !== 'confirmed') {
  pageError = data.status === 'cancelled'
    ? t('reschedule.already_cancelled')
    : t('reschedule.already_modified');
} 
else {
  booking = data;
}

let formattedCurrentDate = '—';
let formattedCurrentTime = '—';

if (booking?.date_time) {

  const dt = new Date(booking.date_time);

  formattedCurrentDate = dt.toLocaleDateString(
    Astro.currentLocale,
    {
      weekday: 'long',
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    }
  );

  formattedCurrentTime = dt.toLocaleTimeString(
    Astro.currentLocale,
    {
      hour: 'numeric',
      minute: '2-digit',
      hour12: true
    }
  );
}

const pageTitle          = t('reschedule.title');
const currentAppointment = t('reschedule.current_appointment');
const nameLabel          = t('reschedule.name');
const dateLabel          = t('reschedule.date');
const timeLabel          = t('reschedule.time');
const reasonLabel        = t('reschedule.reason');
const submitButton       = t('reschedule.submit_button');

const successMsg         = t('reschedule.success_message');
const errorMsg           = t('reschedule.error_message');

const selectDateFirst    = t('booking.select_date_first');
const noTimesAvailable   = t('booking.no_times_available');
const dateTriggerDefault = t('booking.date_trigger_default');
const timeTriggerDefault = t('booking.time_trigger_default');
---

<BaseLayout title={pageTitle}>

<section class="booking-form">

<div class="booking-form__container">

<h1 class="booking-form__title">{pageTitle}</h1>

{
pageError ? (

<div class="booking-form__message error">
{pageError}
</div>

) : booking ? (

<>

<div class="current-appointment-info">

<h3>{currentAppointment}</h3>

<p><strong>{nameLabel}:</strong> {booking.full_name}</p>

<p><strong>{dateLabel}:</strong> {formattedCurrentDate}</p>

<p><strong>{timeLabel}:</strong> {formattedCurrentTime}</p>

{booking.reason && (
<p><strong>{reasonLabel}:</strong> {booking.reason}</p>
)}

</div>

<form id="rescheduleForm" class="booking-form__form">

<input type="hidden" name="booking_id" value={booking.id} />
<input type="hidden" name="token" value={token} />
<input type="hidden" name="full_name" value={booking.full_name} />
<input type="hidden" name="email" value={booking.email} />

<input type="hidden" id="datetime" name="datetime" />

<div class="booking-form__row date-time-row">

<div class="booking-form__group half">

<label>{dateLabel} <span class="required">*</span></label>

<div
class="custom-picker-trigger"
id="date-trigger"
tabindex="0"
role="button"
>
{dateTriggerDefault}
</div>

<div class="dropdown-menu hidden" id="date-dropdown">
<div class="scroll-container" id="date-scroll"></div>
</div>

</div>

<div class="booking-form__group half">

<label>{timeLabel} <span class="required">*</span></label>

<div
class="custom-picker-trigger"
id="time-trigger"
tabindex="0"
role="button"
>
{timeTriggerDefault}
</div>

<div class="dropdown-menu hidden" id="time-dropdown">
<div class="scroll-container" id="time-scroll"></div>
</div>

</div>

</div>

<div
id="message"
class="booking-form__message booking-form__message--hidden"
data-success-msg={successMsg}
data-error-msg={errorMsg}
></div>

<button type="submit" class="booking-form__submit">
{submitButton}
</button>

</form>

</>

) : (

<div class="booking-form__message error">
{t('reschedule.invalid_link')}
</div>

)

}

</div>

</section>

<script>

const CREATE_URL = `/api/reschedule`;
const AVAILABILITY_URL = `${import.meta.env.PUBLIC_SUPABASE_URL}/functions/v1/check-booked-times`;

const form = document.getElementById('rescheduleForm');

const messageDiv = document.getElementById('message');

const successMsg = messageDiv.dataset.successMsg;
const errorMsgBase = messageDiv.dataset.errorMsg;

const locale = document.documentElement.lang || 'ar';
const isArabic = locale.startsWith('ar');

const t = {

dateTriggerDefault:
isArabic ? 'اختر التاريخ ←' : 'Choose date ←',

timeTriggerDefault:
isArabic ? 'اختر الوقت ←' : 'Choose time ←',

selectDateFirst:
isArabic ? 'اختر التاريخ أولاً' : 'Select date first',

noTimesAvailable:
isArabic ? 'لا توجد مواعيد متاحة' : 'No times available',

noAppointmentsDays:
isArabic
? 'لا توجد مواعيد متاحة في الفترة القادمة'
: 'No appointments available in the upcoming days',

fetchError:
isArabic ? 'خطأ في جلب المواعيد' : 'Failed to load appointments',

sending:
isArabic ? 'جاري الإرسال...' : 'Submitting...',

missingDateTime:
isArabic
? 'يرجى اختيار التاريخ والوقت'
: 'Please select date and time',

loadingAppointments:
isArabic
? 'جاري تحميل المواعيد...'
: 'Loading appointments...'

};

let selectedDate = '';
let selectedTime = '';

let dateOriginalText = '';
let timeOriginalText = '';

function showMessage(text, type = 'info') {

messageDiv.classList.remove(
'booking-form__message--hidden',
'success',
'error'
);

messageDiv.classList.add(
type === 'success' ? 'success' : 'error'
);

messageDiv.textContent = text;

}

function hideMessage() {

messageDiv.classList.add(
'booking-form__message--hidden'
);

}

function resetPickers() {

selectedDate = '';
selectedTime = '';

document.getElementById('date-trigger').textContent =
t.dateTriggerDefault;

document.getElementById('time-trigger').textContent =
t.timeTriggerDefault;

document.getElementById('datetime').value = '';

document
.querySelectorAll('.scroll-item.selected')
.forEach(el => el.classList.remove('selected'));

}

form.addEventListener('submit', async (e) => {

e.preventDefault();

hideMessage();

if (!selectedDate || !selectedTime) {

showMessage(t.missingDateTime, 'error');

return;

}

const payload = new FormData(form);

payload.set(
'datetime',
`${selectedDate}T${selectedTime}:00`
);

showMessage(t.sending);

try {

const res = await fetch(
CREATE_URL,
{
method: 'POST',
body: payload
}
);

const result = await res.json();

if (res.ok) {

showMessage(
result.message || successMsg,
'success'
);

form.reset();

resetPickers();

}
else {

throw new Error(
result.error || errorMsgBase
);

}

}
catch (err) {

showMessage(
err.message || errorMsgBase,
'error'
);

}

});

const dateTrigger = document.getElementById('date-trigger');
const dateDropdown = document.getElementById('date-dropdown');
const dateScroll = document.getElementById('date-scroll');

async function generateDates() {

dateScroll.innerHTML =
`<div class="scroll-item disabled">${t.loadingAppointments}</div>`;

try {

const res = await fetch(
AVAILABILITY_URL,
{
method: 'POST',
headers: {
'Content-Type': 'application/json'
},
body: JSON.stringify({
query_type: "available_dates_next_days",
days: 15
})
}
);

const { available_dates = [] } =
await res.json();

dateScroll.innerHTML = '';

if (available_dates.length === 0) {

dateScroll.innerHTML =
`<div class="scroll-item disabled">${t.noAppointmentsDays}</div>`;

return;

}

available_dates.forEach(dateStr => {

const d = new Date(dateStr);

const dayName =
d.toLocaleDateString(locale,
{ weekday: 'long' });

const monthName =
d.toLocaleDateString(locale,
{ month: 'long' });

const dayNum =
d.getDate()
.toString()
.padStart(2, '0');

const year = d.getFullYear();

const display =
isArabic
? `${dayName} ${dayNum} ${monthName} ${year}`
: `${dayName}, ${monthName} ${dayNum}, ${year}`;

const item = document.createElement('div');

item.className = 'scroll-item';

item.dataset.value = dateStr;

item.textContent = display;

dateScroll.appendChild(item);

});

}
catch {

dateScroll.innerHTML =
`<div class="scroll-item disabled">${t.fetchError}</div>`;

}

}

dateTrigger.addEventListener('click', async (e) => {

e.stopPropagation();

const willOpen =
dateDropdown.classList.contains('hidden');

document
.getElementById('time-dropdown')
?.classList.add('hidden');

if (!willOpen) {

dateDropdown.classList.add('hidden');

}
else {

dateOriginalText =
dateTrigger.textContent;

dateTrigger.textContent =
t.loadingAppointments;

await generateDates();

dateTrigger.textContent =
dateOriginalText;

dateDropdown.classList.remove('hidden');

}

});

dateScroll.addEventListener('click', (e) => {

const item =
e.target.closest('.scroll-item');

if (!item ||
item.classList.contains('disabled'))
return;

dateScroll
.querySelectorAll('.scroll-item')
.forEach(el => el.classList.remove('selected'));

item.classList.add('selected');

dateTrigger.textContent =
item.textContent;

selectedDate = item.dataset.value;

dateDropdown.classList.add('hidden');

generateTimes();

});

const timeTrigger =
document.getElementById('time-trigger');

const timeDropdown =
document.getElementById('time-dropdown');

const timeScroll =
document.getElementById('time-scroll');

async function generateTimes() {

timeScroll.innerHTML =
`<div class="scroll-item disabled">${t.loadingAppointments}</div>`;

if (!selectedDate) {

timeScroll.innerHTML =
`<div class="scroll-item disabled">${t.selectDateFirst}</div>`;

return;

}

try {

const res = await fetch(
AVAILABILITY_URL,
{
method: 'POST',
headers: {
'Content-Type': 'application/json'
},
body: JSON.stringify({
query_type: "available_times_for_date",
date: selectedDate
})
}
);

const { available_times = [] } =
await res.json();

timeScroll.innerHTML = '';

if (available_times.length === 0) {

timeScroll.innerHTML =
`<div class="scroll-item disabled">${t.noTimesAvailable}</div>`;

return;

}

available_times.forEach(time24 => {

const [hourStr, minuteStr] =
time24.split(':');

const hour = parseInt(hourStr, 10);
const minute = parseInt(minuteStr, 10);

let display;

if (isArabic) {

if (hour === 12) {

display =
`12:${minute.toString().padStart(2,'0')} ظهرًا`;

}
else if (hour > 12) {

display =
`${(hour-12).toString().padStart(2,'0')}:${minute.toString().padStart(2,'0')} مساءً`;

}
else {

display =
`${hour.toString().padStart(2,'0')}:${minute.toString().padStart(2,'0')} صباحًا`;

}

}
else {

const h = (hour % 12) || 12;

display =
`${h}:${minute.toString().padStart(2,'0')} ${hour<12?'AM':'PM'}`;

}

const item = document.createElement('div');

item.className = 'scroll-item';

item.dataset.value = time24;

item.textContent = display;

timeScroll.appendChild(item);

});

}
catch {

timeScroll.innerHTML =
`<div class="scroll-item disabled">${t.fetchError}</div>`;

}

}

timeTrigger.addEventListener('click', async (e) => {

e.stopPropagation();

const willOpen =
timeDropdown.classList.contains('hidden');

document
.getElementById('date-dropdown')
?.classList.add('hidden');

if (!willOpen) {

timeDropdown.classList.add('hidden');

}
else {

timeOriginalText =
timeTrigger.textContent;

timeTrigger.textContent =
t.loadingAppointments;

await generateTimes();

timeTrigger.textContent =
timeOriginalText;

timeDropdown.classList.remove('hidden');

}

});

timeScroll.addEventListener('click', (e) => {

const item =
e.target.closest('.scroll-item');

if (!item ||
item.classList.contains('disabled'))
return;

timeScroll
.querySelectorAll('.scroll-item')
.forEach(el => el.classList.remove('selected'));

item.classList.add('selected');

timeTrigger.textContent =
item.textContent;

selectedTime = item.dataset.value;

timeDropdown.classList.add('hidden');

});

document.addEventListener('click', (e) => {

if (!dateTrigger.contains(e.target)
&& !dateDropdown.contains(e.target)) {

dateDropdown.classList.add('hidden');

}

if (!timeTrigger.contains(e.target)
&& !timeDropdown.contains(e.target)) {

timeDropdown.classList.add('hidden');

}

});

</script>

</BaseLayout>

<style is:global>

:root{
--primary:#4f46e5;
--primary-hover:#4338ca;
--border:#e5e7eb;
--text:#111827;
--muted:#6b7280;
--bg:#f9fafb;
--success:#16a34a;
--error:#dc2626;
}

.booking-form{
padding:60px 20px;
display:flex;
justify-content:center;
background:var(--bg);
}

.booking-form__container{
width:100%;
max-width:760px;
background:#fff;
padding:42px;
border-radius:16px;
box-shadow:0 20px 50px rgba(0,0,0,.08);
}

.booking-form__title{
font-size:30px;
font-weight:700;
margin-bottom:30px;
text-align:center;
color:var(--text);
}

/* current appointment */

.current-appointment-info{
background:#f3f4f6;
border:1px solid var(--border);
padding:22px;
border-radius:12px;
margin-bottom:32px;
line-height:1.9;
}

.current-appointment-info h3{
font-size:18px;
margin-bottom:10px;
}

/* form */

.booking-form__form{
display:flex;
flex-direction:column;
gap:24px;
}

.booking-form__row{
display:flex;
gap:18px;
}

.booking-form__group{
flex:1;
display:flex;
flex-direction:column;
gap:8px;
position:relative;
}

label{
font-size:14px;
font-weight:600;
color:var(--text);
}

.required{
color:var(--error);
}

/* triggers */

.custom-picker-trigger{
border:1px solid var(--border);
padding:14px;
border-radius:10px;
cursor:pointer;
background:white;
font-size:14px;
transition:all .2s ease;
display:flex;
align-items:center;
justify-content:space-between;
}

.custom-picker-trigger:hover{
border-color:var(--primary);
box-shadow:0 0 0 3px rgba(79,70,229,.08);
}

/* dropdown */

.dropdown-menu{
position:absolute;
top:100%;
left:0;
right:0;
margin-top:8px;
background:#fff;
border:1px solid var(--border);
border-radius:12px;
box-shadow:0 20px 40px rgba(0,0,0,.1);
z-index:100;
overflow:hidden;
}

.hidden{
display:none;
}

/* scroll container */

.scroll-container{
max-height:220px;
overflow-y:auto;
}

/* FIX FOR SCROLL ITEMS */

.booking-form .scroll-container .scroll-item{
padding:12px 16px;
font-size:14px;
cursor:pointer;
border-bottom:1px solid #f3f4f6;
transition:all .15s ease;
background:white;
}

.booking-form .scroll-container .scroll-item:last-child{
border-bottom:none;
}

.booking-form .scroll-container .scroll-item:hover{
background:#f5f7ff;
}

.booking-form .scroll-container .scroll-item.selected{
background:#eef2ff;
color:var(--primary);
font-weight:600;
}

.booking-form .scroll-container .scroll-item.disabled{
color:#9ca3af;
cursor:default;
background:#fafafa;
}

/* submit button */

.booking-form__submit{
margin-top:8px;
padding:15px;
border:none;
border-radius:10px;
background:var(--primary);
color:white;
font-size:16px;
font-weight:600;
cursor:pointer;
transition:all .2s ease;
}

.booking-form__submit:hover{
background:var(--primary-hover);
transform:translateY(-1px);
}

/* messages */

.booking-form__message{
padding:14px;
border-radius:8px;
font-size:14px;
}

.booking-form__message.success{
background:#ecfdf5;
color:var(--success);
border:1px solid #bbf7d0;
}

.booking-form__message.error{
background:#fef2f2;
color:var(--error);
border:1px solid #fecaca;
}

.booking-form__message--hidden{
display:none;
}

/* RTL support */

html[lang="ar"] .booking-form__container{
direction:rtl;
}

html[lang="ar"] .scroll-item{
text-align:right;
}

/* scrollbar modern */

.scroll-container::-webkit-scrollbar{
width:6px;
}

.scroll-container::-webkit-scrollbar-thumb{
background:#d1d5db;
border-radius:4px;
}

/* mobile */

@media (max-width:640px){

.booking-form__container{
padding:28px;
}

.booking-form__row{
flex-direction:column;
}

.booking-form__title{
font-size:24px;
}

}

</style>


      
