---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils.ts';
import { createClient } from '@supabase/supabase-js';

const t = useTranslations(Astro.currentLocale ?? 'ar');

const { token } = Astro.params;

if (!token) {
  return Astro.redirect('/404');
}

const { locals } = Astro;
const env = locals.runtime.env;

const supabaseUrl = env.PUBLIC_SUPABASE_URL || env.SUPABASE_URL;
const serviceRoleKey = env.SUPABASE_SERVICE_ROLE_KEY;

if (!supabaseUrl || !serviceRoleKey) {
  console.error('Missing Supabase configuration');
  return Astro.redirect('/error?msg=server-config');
}

const supabase = createClient(
  supabaseUrl,
  serviceRoleKey,
  {
    auth:{
      autoRefreshToken:false,
      persistSession:false,
      detectSessionInUrl:false
    }
  }
);

let booking = null;
let pageError = null;

const { data, error } = await supabase
  .from('appointments')
  .select('id, full_name, email, date_time, reason, status')
  .eq('manage_token', token)
  .single();

if (error || !data) {
  pageError = t('reschedule.invalid_link');
}
else if (data.status !== 'confirmed') {
  pageError = data.status === 'cancelled'
    ? t('reschedule.already_cancelled')
    : t('reschedule.already_modified');
}
else {
  booking = data;
}

let formattedCurrentDate = '—';
let formattedCurrentTime = '—';

if (booking?.date_time) {

  const dt = new Date(booking.date_time);

  formattedCurrentDate = dt.toLocaleDateString(
    Astro.currentLocale,
    { weekday:'long', year:'numeric', month:'long', day:'numeric' }
  );

  formattedCurrentTime = dt.toLocaleTimeString(
    Astro.currentLocale,
    { hour:'numeric', minute:'2-digit', hour12:true }
  );
}

const pageTitle = t('reschedule.title');
const currentAppointment = t('reschedule.current_appointment');
const nameLabel = t('reschedule.name');
const dateLabel = t('reschedule.date');
const timeLabel = t('reschedule.time');
const reasonLabel = t('reschedule.reason');
const submitButton = t('reschedule.submit_button');

const successMsg = t('reschedule.success_message');
const errorMsg = t('reschedule.error_message');
---

<BaseLayout title={pageTitle}>

<section class="booking-form">

<div class="booking-form__container">

<h1 class="booking-form__title">{pageTitle}</h1>

{
pageError ? (

<div class="booking-form__message error">
{pageError}
</div>

) : booking ? (

<>

<div class="current-appointment-info">

<h3>{currentAppointment}</h3>

<p><strong>{nameLabel}:</strong> {booking.full_name}</p>
<p><strong>{dateLabel}:</strong> {formattedCurrentDate}</p>
<p><strong>{timeLabel}:</strong> {formattedCurrentTime}</p>

{booking.reason && (
<p><strong>{reasonLabel}:</strong> {booking.reason}</p>
)}

</div>

<form id="rescheduleForm" class="booking-form__form">

<input type="hidden" name="booking_id" value={booking.id} />
<input type="hidden" name="token" value={token} />
<input type="hidden" name="full_name" value={booking.full_name} />
<input type="hidden" name="email" value={booking.email} />

<input type="hidden" id="datetime" name="datetime" />

<div class="booking-form__group">

<label>{dateLabel} <span class="required">*</span></label>

<div id="date-list" class="slots-grid"></div>

</div>

<div class="booking-form__group">

<label>{timeLabel} <span class="required">*</span></label>

<div id="time-list" class="slots-grid"></div>

</div>

<div
id="message"
class="booking-form__message booking-form__message--hidden"
data-success-msg={successMsg}
data-error-msg={errorMsg}
></div>

<button type="submit" class="booking-form__submit">
{submitButton}
</button>

</form>

</>

) : (

<div class="booking-form__message error">
{t('reschedule.invalid_link')}
</div>

)

}

</div>

</section>

<script>

const CREATE_URL = `/api/reschedule`;
const AVAILABILITY_URL = `${import.meta.env.PUBLIC_SUPABASE_URL}/functions/v1/check-booked-times`;

const form = document.getElementById("rescheduleForm");
const messageDiv = document.getElementById("message");

const successMsg = messageDiv.dataset.successMsg;
const errorMsgBase = messageDiv.dataset.errorMsg;

const locale = document.documentElement.lang || "ar";
const isArabic = locale.startsWith("ar");

const dateList = document.getElementById("date-list");
const timeList = document.getElementById("time-list");

let selectedDate = "";
let selectedTime = "";

function showMessage(text,type="info"){

messageDiv.classList.remove("booking-form__message--hidden","success","error");

messageDiv.classList.add(type==="success"?"success":"error");

messageDiv.textContent=text;

}

function hideMessage(){

messageDiv.classList.add("booking-form__message--hidden");

}

async function loadDates(){

dateList.innerHTML=`<div class="slot disabled">Loading...</div>`;

try{

const res=await fetch(AVAILABILITY_URL,{
method:"POST",
headers:{'Content-Type':'application/json'},
body:JSON.stringify({
query_type:"available_dates_next_days",
days:15
})
});

const { available_dates=[] }=await res.json();

dateList.innerHTML="";

available_dates.forEach(dateStr=>{

const d=new Date(dateStr);

const day=d.toLocaleDateString(locale,{weekday:"long"});
const month=d.toLocaleDateString(locale,{month:"long"});
const num=d.getDate();

const display=isArabic
? `${day} ${num} ${month}`
: `${day}, ${month} ${num}`;

const div=document.createElement("div");

div.className="slot";
div.dataset.value=dateStr;
div.textContent=display;

dateList.appendChild(div);

});

}catch{

dateList.innerHTML=`<div class="slot disabled">Error loading dates</div>`;

}

}

dateList.addEventListener("click",e=>{

const slot=e.target.closest(".slot");

if(!slot||slot.classList.contains("disabled")) return;

document.querySelectorAll("#date-list .slot")
.forEach(el=>el.classList.remove("selected"));

slot.classList.add("selected");

selectedDate=slot.dataset.value;

selectedTime="";

timeList.innerHTML="";

loadTimes();

});

async function loadTimes(){

timeList.innerHTML=`<div class="slot disabled">Loading...</div>`;

try{

const res=await fetch(AVAILABILITY_URL,{
method:"POST",
headers:{'Content-Type':'application/json'},
body:JSON.stringify({
query_type:"available_times_for_date",
date:selectedDate
})
});

const { available_times=[] }=await res.json();

timeList.innerHTML="";

available_times.forEach(time24=>{

const [h,m]=time24.split(":");
const hour=parseInt(h);

let display;

if(isArabic){

if(hour===12) display=`12:${m} ظهرًا`;
else if(hour>12) display=`${hour-12}:${m} مساءً`;
else display=`${hour}:${m} صباحًا`;

}else{

const hh=(hour%12)||12;
display=`${hh}:${m} ${hour<12?'AM':'PM'}`;

}

const div=document.createElement("div");

div.className="slot";
div.dataset.value=time24;
div.textContent=display;

timeList.appendChild(div);

});

}catch{

timeList.innerHTML=`<div class="slot disabled">Error loading times</div>`;

}

}

timeList.addEventListener("click",e=>{

const slot=e.target.closest(".slot");

if(!slot||slot.classList.contains("disabled")) return;

document.querySelectorAll("#time-list .slot")
.forEach(el=>el.classList.remove("selected"));

slot.classList.add("selected");

selectedTime=slot.dataset.value;

});

form.addEventListener("submit",async e=>{

e.preventDefault();

hideMessage();

if(!selectedDate||!selectedTime){

showMessage("يرجى اختيار التاريخ والوقت","error");
return;

}

const payload=new FormData(form);

payload.set("datetime",`${selectedDate}T${selectedTime}:00`);

try{

const res=await fetch(CREATE_URL,{method:"POST",body:payload});

const result=await res.json();

if(res.ok){

showMessage(result.message||successMsg,"success");

}else{

throw new Error(result.error||errorMsgBase);

}

}catch(err){

showMessage(err.message||errorMsgBase,"error");

}

});

loadDates();

</script>

<style>

.booking-form{
padding:4rem 1rem;
background:linear-gradient(135deg,#f8fafc 0%,#e2e8f0 100%);
min-height:100vh;
display:flex;
align-items:center;
justify-content:center;
}

.booking-form__container{
background:white;
padding:2.5rem;
border-radius:1rem;
box-shadow:0 10px 30px rgba(0,0,0,0.08);
max-width:520px;
width:100%;
}

.booking-form__title{
font-size:2rem;
font-weight:700;
text-align:center;
margin-bottom:2rem;
}

.booking-form__form{
display:flex;
flex-direction:column;
gap:1.6rem;
}

.booking-form__group{
display:flex;
flex-direction:column;
gap:0.6rem;
}

.required{color:#ef4444}

.slots-grid{
display:grid;
grid-template-columns:repeat(auto-fill,minmax(130px,1fr));
gap:10px;
}

.slot{
padding:10px;
border:1px solid #d1d5db;
border-radius:8px;
text-align:center;
cursor:pointer;
background:#f9fafb;
}

.slot:hover{
background:#eff6ff;
}

.slot.selected{
background:#2563eb;
color:white;
border-color:#2563eb;
font-weight:600;
}

.slot.disabled{
background:#f3f4f6;
color:#9ca3af;
cursor:not-allowed;
}

.booking-form__submit{
margin-top:1rem;
padding:1rem;
background:linear-gradient(90deg,#3b82f6,#6366f1);
color:white;
border:none;
border-radius:0.6rem;
font-weight:600;
cursor:pointer;
}

.booking-form__message{
padding:1rem;
border-radius:0.6rem;
text-align:center;
margin-top:1rem;
}

.booking-form__message--hidden{display:none}

.success{
background:#ecfdf5;
color:#065f46;
}

.error{
background:#fef2f2;
color:#991b1b;
}

</style>

</BaseLayout>
