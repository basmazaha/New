---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations } from '../../../i18n/utils.ts';
import { createClient } from '@supabase/supabase-js';

const t = useTranslations(Astro.currentLocale ?? 'ar');

const { token } = Astro.params;

if (!token) {
  return Astro.redirect('/404');
}

const { locals } = Astro;
const env = locals.runtime.env;

const supabaseUrl = env.PUBLIC_SUPABASE_URL || env.SUPABASE_URL;

const CREATE_URL = `${supabaseUrl}/functions/v1/create-appointment`;
const AVAILABILITY_URL = `${supabaseUrl}/functions/v1/check-booked-times`;
const serviceRoleKey = env.SUPABASE_SERVICE_ROLE_KEY;

if (!supabaseUrl || !serviceRoleKey) {
  console.error('Missing Supabase configuration in environment variables');
  return Astro.redirect('/error?msg=server-config');
}

const supabase = createClient(
  supabaseUrl,
  serviceRoleKey,
  {
    auth: {
      autoRefreshToken: false,
      persistSession: false,
      detectSessionInUrl: false
    }
  }
);

let booking = null;
let pageError = null;

const { data: settings } = await supabase
  .from("business_settings")
  .select("timezone")
  .maybeSingle();

const businessTimezone = settings?.timezone || "Africa/Cairo";

const { data, error } = await supabase
  .from('appointments')
  .select('id, full_name, email, date_time, reason, status')
  .eq('manage_token', token)
  .single();

if (error || !data) {
  pageError = t('reschedule.invalid_link');
} 
else if (data.status !== 'confirmed') {
  pageError = data.status === 'cancelled'
    ? t('reschedule.already_cancelled')
    : t('reschedule.already_modified');
} 
else {
  booking = data;
}

let formattedCurrentDate = '—';
let formattedCurrentTime = '—';

if (booking?.date_time) {

  const dt = new Date(booking.date_time);

  formattedCurrentDate = dt.toLocaleDateString(
    Astro.currentLocale,
    {
      weekday: 'long',
      year: 'numeric',
      month: 'long',
      day: 'numeric',
      timeZone: businessTimezone
    }
  );

  formattedCurrentTime = dt.toLocaleTimeString(
    Astro.currentLocale,
    {
      hour: 'numeric',
      minute: '2-digit',
      hour12: true,
      timeZone: businessTimezone
    }
  );
}

const pageTitle          = t('reschedule.title');
const currentAppointment = t('reschedule.current_appointment');
const nameLabel          = t('reschedule.name');
const dateLabel          = t('reschedule.date');
const timeLabel          = t('reschedule.time');
const reasonLabel        = t('reschedule.reason');
const submitButton       = t('reschedule.submit_button');

const successMsg         = t('reschedule.success_message');
const errorMsg           = t('reschedule.error_message');

const selectDateFirst    = t('booking.select_date_first');
const noTimesAvailable   = t('booking.no_times_available');
const dateTriggerDefault = t('booking.date_trigger_default');
const timeTriggerDefault = t('booking.time_trigger_default');

const noAppointmentsDays  = t('booking.ui.no_appointments_days');
const fetchError          = t('booking.ui.fetch_error');
const sending             = t('booking.ui.sending');
const missingDateTime     = t('booking.ui.missing_datetime');
const loadingAppointments = t('booking.ui.loading_appointments');

const submitting          = t('reschedule.submitting');
---

<BaseLayout title={pageTitle}>

<section class="booking-form">

<div class="booking-form__container">

<h1 class="booking-form__title">{pageTitle}</h1>

{
pageError ? (

<div class="booking-form__message error">
{pageError}
</div>

) : booking ? (

<>

<div class="current-appointment-info">

<h3>{currentAppointment}</h3>

<p><strong>{nameLabel}:</strong> {booking.full_name}</p>

<p><strong>{dateLabel}:</strong> {formattedCurrentDate}</p>

<p><strong>{timeLabel}:</strong> {formattedCurrentTime}</p>

{booking.reason && (
<p><strong>{reasonLabel}:</strong> {booking.reason}</p>
)}

</div>

<form id="rescheduleForm" class="booking-form__form">

<input type="hidden" name="booking_id" value={booking.id} />
<input type="hidden" name="token" value={token} />
<input type="hidden" name="full_name" value={booking.full_name} />
<input type="hidden" name="email" value={booking.email} />

<input type="hidden" id="datetime" name="datetime" />

<div class="booking-form__row date-time-row">

<div class="booking-form__group half">

<label>{dateLabel} <span class="required">*</span></label>

<div
class="custom-picker-trigger"
id="date-trigger"
tabindex="0"
role="button"
>
{dateTriggerDefault}
</div>

<div class="dropdown-menu hidden" id="date-dropdown">
<div class="scroll-container" id="date-scroll"></div>
</div>

</div>

<div class="booking-form__group half">

<label>{timeLabel} <span class="required">*</span></label>

<div
class="custom-picker-trigger"
id="time-trigger"
tabindex="0"
role="button"
>
{timeTriggerDefault}
</div>

<div class="dropdown-menu hidden" id="time-dropdown">
<div class="scroll-container" id="time-scroll"></div>
</div>

</div>

</div>

<div
id="message"
class="booking-form__message booking-form__message--hidden"
data-success-msg={successMsg}
data-error-msg={errorMsg}
></div>

<button type="submit" class="booking-form__submit">
{submitButton}
</button>

</form>

</>

) : (

<div class="booking-form__message error">
{t('reschedule.invalid_link')}
</div>

)

}

</div>

</section>

<script define:vars={{
  CREATE_URL,
  AVAILABILITY_URL,
  dateTriggerDefault,
  timeTriggerDefault,
  selectDateFirst,
  noTimesAvailable,
  noAppointmentsDays,
  fetchError,
  sending,
  missingDateTime,
  loadingAppointments,
  submitting
}}>


const form = document.getElementById('rescheduleForm');

const messageDiv = document.getElementById('message');

const successMsg = messageDiv.dataset.successMsg;
const errorMsgBase = messageDiv.dataset.errorMsg;

const locale = document.documentElement.lang || 'ar';
const isArabic = locale.startsWith('ar');

const i18n = {
  dateTriggerDefault,
  timeTriggerDefault,
  selectDateFirst,
  noTimesAvailable,
  noAppointmentsDays,
  fetchError,
  sending,
  missingDateTime,
  loadingAppointments,
  submitting
};

let selectedDate = '';
let selectedTime = '';

let dateOriginalText = '';
let timeOriginalText = '';

let availableDatesCache = null;
let availableTimesCache = {};

function showMessage(text, type = 'info') {

messageDiv.classList.remove(
'booking-form__message--hidden',
'success',
'error'
);

messageDiv.classList.add(
type === 'success' ? 'success' : 'error'
);

messageDiv.textContent = text;

}

function hideMessage() {

messageDiv.classList.add(
'booking-form__message--hidden'
);

}

function resetPickers() {

selectedDate = '';
selectedTime = '';

document.getElementById('date-trigger').textContent =
i18n.dateTriggerDefault;

document.getElementById('time-trigger').textContent =
i18n.timeTriggerDefault;

document.getElementById('datetime').value = '';

document
.querySelectorAll('.scroll-item.selected')
.forEach(el => el.classList.remove('selected'));

}

form.addEventListener('submit', async (e) => {

e.preventDefault();

hideMessage();

if (!selectedDate || !selectedTime) {

showMessage(i18n.missingDateTime, 'error');

return;

}

const payload = {
  booking_id: form.booking_id.value,
  token: form.token.value,
  full_name: form.full_name.value,
  email: form.email.value,
  datetime: `${selectedDate}T${selectedTime}:00`
};

showMessage(i18n.submitting);

try {

const res = await fetch(
CREATE_URL,
{
method: 'POST',
headers: {
'Content-Type': 'application/json'
},
body: JSON.stringify(payload)
}
);

const result = await res.json();

if (res.ok) {

showMessage(
result.message || successMsg,
'success'
);

form.reset();

resetPickers();

}
else {

throw new Error(
result.error || errorMsgBase
);

}

}
catch (err) {

showMessage(
err.message || errorMsgBase,
'error'
);

}

});

const dateTrigger = document.getElementById('date-trigger');
const dateDropdown = document.getElementById('date-dropdown');
const dateScroll = document.getElementById('date-scroll');

async function generateDates() {

dateScroll.innerHTML =
`<div class="scroll-item disabled">${i18n.loadingAppointments}</div>`;

try {

let available_dates = [];

if (availableDatesCache) {

  available_dates = availableDatesCache;

} else {

  const res = await fetch(
    AVAILABILITY_URL,
    {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        query_type: "available_dates_next_days",
        days: 15
      })
    }
  );

  const data = await res.json();

  available_dates = data.available_dates || [];

  availableDatesCache = available_dates;

}

dateScroll.innerHTML = '';

if (available_dates.length === 0) {

dateScroll.innerHTML =
`<div class="scroll-item disabled">${i18n.noAppointmentsDays}</div>`;

return;

}

available_dates.forEach(dateStr => {

const d = new Date(dateStr);

const dayName =
d.toLocaleDateString(locale,{ weekday: 'long' });

const monthName =
d.toLocaleDateString(locale,{ month: 'long' });

const dayNum =
d.getDate().toString().padStart(2,'0');

const year = d.getFullYear();

const display =
isArabic
? `${dayName} ${dayNum} ${monthName} ${year}`
: `${dayName}, ${monthName} ${dayNum}, ${year}`;

const item = document.createElement('div');

item.className = 'scroll-item';
item.dataset.value = dateStr;
item.textContent = display;

/* هنا الإضافة الجديدة */
if (dateStr === selectedDate) {
item.classList.add('selected');
}

dateScroll.appendChild(item);

});

/* النزول تلقائياً إلى الوقت المختار */

setTimeout(() => {

const selectedItem = dateScroll.querySelector('.scroll-item.selected');

if (selectedItem) {

selectedItem.scrollIntoView({
behavior: 'auto',
block: 'center'
});

}

}, 50);

}
catch {

dateScroll.innerHTML =
`<div class="scroll-item disabled">${i18n.fetchError}</div>`;

}

}

dateTrigger.addEventListener('click', async (e) => {

e.stopPropagation();

const willOpen =
dateDropdown.classList.contains('hidden');

document
.getElementById('time-dropdown')
?.classList.add('hidden');

if (!willOpen) {

dateDropdown.classList.add('hidden');

}
else {

dateOriginalText =
dateTrigger.textContent;

dateTrigger.textContent =
i18n.loadingAppointments;

await generateDates();

dateTrigger.textContent =
dateOriginalText;

dateDropdown.classList.remove('hidden');

}

});

dateScroll.addEventListener('click', (e) => {

const item =
e.target.closest('.scroll-item');

if (!item ||
item.classList.contains('disabled'))
return;

dateScroll
.querySelectorAll('.scroll-item')
.forEach(el => el.classList.remove('selected'));

item.classList.add('selected');

dateTrigger.textContent =
item.textContent;

selectedDate = item.dataset.value;

dateDropdown.classList.add('hidden');

/* reset الوقت عند تغيير التاريخ */
selectedTime = '';
document.getElementById('time-trigger').textContent =
i18n.timeTriggerDefault;

generateTimes();

});

const timeTrigger =
document.getElementById('time-trigger');

const timeDropdown =
document.getElementById('time-dropdown');

const timeScroll =
document.getElementById('time-scroll');

async function generateTimes() {

timeScroll.innerHTML =
`<div class="scroll-item disabled">${i18n.loadingAppointments}</div>`;

if (!selectedDate) {

timeScroll.innerHTML =
`<div class="scroll-item disabled">${i18n.selectDateFirst}</div>`;

return;

}

try {

let available_times = [];

if (availableTimesCache[selectedDate]) {

  available_times = availableTimesCache[selectedDate];

} else {

  const res = await fetch(
    AVAILABILITY_URL,
    {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        query_type: "available_times_for_date",
        date: selectedDate
      })
    }
  );

  const data = await res.json();

  available_times = data.available_times || [];

  availableTimesCache[selectedDate] = available_times;

}

timeScroll.innerHTML = '';

if (available_times.length === 0) {

timeScroll.innerHTML =
`<div class="scroll-item disabled">${i18n.noTimesAvailable}</div>`;

return;

}

available_times.forEach(time24 => {

const [hourStr, minuteStr] = time24.split(':');

const hour = parseInt(hourStr, 10);
const minute = parseInt(minuteStr, 10);

let display;

if (isArabic) {

  if (hour === 12) {

    display =
      `12:${minute.toString().padStart(2,'0')} ظهرًا`;

  }
  else if (hour > 12) {

    display =
      `${(hour-12).toString().padStart(2,'0')}:${minute.toString().padStart(2,'0')} مساءً`;

  }
  else {

    display =
      `${hour.toString().padStart(2,'0')}:${minute.toString().padStart(2,'0')} صباحًا`;

  }

}
else {

  const h = (hour % 12) || 12;

  display =
    `${h}:${minute.toString().padStart(2,'0')} ${hour < 12 ? 'AM' : 'PM'}`;

}

const item = document.createElement('div');

item.className = 'scroll-item';

item.dataset.value = time24;

item.textContent = display;

/* إعادة تظليل الوقت المختار عند فتح القائمة مرة أخرى */
if (time24 === selectedTime) {
  item.classList.add('selected');
}

timeScroll.appendChild(item);

});

/* النزول تلقائياً إلى الوقت المختار */

setTimeout(() => {

const selectedItem = timeScroll.querySelector('.scroll-item.selected');

if (selectedItem) {

selectedItem.scrollIntoView({
behavior: 'auto',
block: 'center'
});

}

}, 50);

}
catch {

timeScroll.innerHTML =
`<div class="scroll-item disabled">${i18n.fetchError}</div>`;

}

}

timeTrigger.addEventListener('click', async (e) => {

e.stopPropagation();

const willOpen =
timeDropdown.classList.contains('hidden');

document
.getElementById('date-dropdown')
?.classList.add('hidden');

if (!willOpen) {

timeDropdown.classList.add('hidden');

}
else {

timeOriginalText =
timeTrigger.textContent;

timeTrigger.textContent =
i18n.loadingAppointments;

await generateTimes();

timeTrigger.textContent =
timeOriginalText;

timeDropdown.classList.remove('hidden');

}

});

timeScroll.addEventListener('click', (e) => {

const item =
e.target.closest('.scroll-item');

if (!item ||
item.classList.contains('disabled'))
return;

timeScroll
.querySelectorAll('.scroll-item')
.forEach(el => el.classList.remove('selected'));

item.classList.add('selected');

timeTrigger.textContent =
item.textContent;

selectedTime = item.dataset.value;

timeDropdown.classList.add('hidden');

});

document.addEventListener('click', (e) => {

if (!dateTrigger.contains(e.target)
&& !dateDropdown.contains(e.target)) {

dateDropdown.classList.add('hidden');

}

if (!timeTrigger.contains(e.target)
&& !timeDropdown.contains(e.target)) {

timeDropdown.classList.add('hidden');

}

});

</script>
   
</BaseLayout>




      
