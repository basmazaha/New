---
import { createClient } from '@supabase/supabase-js';

const { locals, request } = Astro;
const env = locals.runtime.env;

const supabaseUrl = env.PUBLIC_SUPABASE_URL;
const serviceRoleKey = env.SUPABASE_SERVICE_ROLE_KEY;

if (!supabaseUrl || !serviceRoleKey) {
  throw new Error("Supabase env vars missing in Cloudflare runtime");
}

const supabase = createClient(supabaseUrl, serviceRoleKey, {
  auth: {
    autoRefreshToken: false,
    persistSession: false,
    detectSessionInUrl: false
  }
});

// استخراج الـ manage_token من query string في الرابط (مثال: /test?token=abc123)
const url = new URL(request.url);
const manage_token = url.searchParams.get('token')?.trim();

let record = null;
let fetchMessage = null;
let editMessage = null;
let editSuccess = false;

if (manage_token) {
  // جلب السجل المحدد فقط باستخدام manage_token
  const { data: foundRecord, error: findError } = await supabase
    .from('appointments')
    .select('id, full_name, manage_token, created_at, status')  // أضف حقول أخرى إذا أردت (مثل appointment_date, appointment_time)
    .eq('manage_token', manage_token)
    .single();

  if (findError || !foundRecord) {
    fetchMessage = 'التوكن غير صالح أو السجل غير موجود';
  } else {
    record = foundRecord;
  }
} else {
  fetchMessage = 'يرجى تقديم manage_token في الرابط (مثال: ?token=abc123)';
}

// معالجة طلب التعديل (POST) - فقط إذا كان التوكن صالحاً
if (request.method === 'POST' && manage_token && record) {
  try {
    const formData = await request.formData();
    const new_full_name = formData.get('new_full_name')?.toString().trim();

    if (new_full_name) {
      const { error: updateError } = await supabase
        .from('appointments')
        .update({ full_name: new_full_name })  // يمكن إضافة حقول أخرى للتعديل هنا (مثل appointment_date, status)
        .eq('manage_token', manage_token);

      if (updateError) {
        console.error("Update error:", updateError);
        editMessage = 'فشل في التعديل: ' + updateError.message;
      } else {
        editSuccess = true;
        editMessage = 'تم تعديل الحجز بنجاح!';

        // إعادة جلب السجل المحدث
        const { data: refreshedRecord } = await supabase
          .from('appointments')
          .select('id, full_name, manage_token, created_at, status')
          .eq('manage_token', manage_token)
          .single();
        record = refreshedRecord;
      }
    } else {
      editMessage = 'بيانات التعديل ناقصة';
    }
  } catch (err) {
    console.error("Edit processing error:", err);
    editMessage = 'خطأ داخلي أثناء معالجة التعديل';
  }
}
---

<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>صفحة إدارة الحجز - اختبار</title>
    <style>
      body { font-family: system-ui, sans-serif; max-width: 800px; margin: 2rem auto; padding: 1rem; line-height: 1.6; }
      h1, h2 { color: #1a3c5e; }
      table { width: 100%; border-collapse: collapse; margin: 2rem 0; font-size: 0.95rem; }
      th, td { border: 1px solid #ddd; padding: 0.7rem; text-align: right; }
      th { background: #f5f7fa; font-weight: 600; }
      .error { color: #c62828; font-weight: bold; background: #ffebee; padding: 0.8rem; border-radius: 4px; margin: 1rem 0; }
      .success { color: #2e7d32; font-weight: bold; background: #e8f5e9; padding: 0.8rem; border-radius: 4px; margin: 1rem 0; }
      form { display: flex; flex-direction: column; gap: 1rem; margin: 2rem 0; padding: 1rem; background: #f9f9f9; border-radius: 8px; }
      input, button { padding: 0.6rem 1rem; font-size: 1rem; border: 1px solid #ccc; border-radius: 4px; }
      button { background: #1976d2; color: white; border: none; cursor: pointer; }
      button:hover { background: #1565c0; }
      .info { margin: 1rem 0; color: #555; }
    </style>
  </head>
  <body>

    <h1>إدارة حجز محدد (اختبار)</h1>

    <p class="info">استخدم الرابط مع ?token=... للوصول إلى حجزك الخاص. لن ترى أي حجوزات أخرى.</p>

    {fetchMessage && (
      <div class="error">{fetchMessage}</div>
    )}

    {record ? (
      <div>
        <h2>تفاصيل الحجز الخاص بك</h2>
        <table>
          <thead>
            <tr>
              <th>المعرف</th>
              <th>الاسم الكامل</th>
              <th>manage_token (مختصر)</th>
              <th>الحالة</th>
              <th>تاريخ الإنشاء</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>{record.id}</td>
              <td>{record.full_name || '(غير محدد)'}</td>
              <td>{record.manage_token.substring(0, 8) + '...'}</td>
              <td>{record.status || '-'}</td>
              <td>{new Date(record.created_at).toLocaleString('ar-EG')}</td>
            </tr>
          </tbody>
        </table>

        <!-- نموذج التعديل (فقط لهذا السجل) -->
        <h2>تعديل الحجز</h2>
        <form method="POST">
          <!-- التوكن مخفي (للأمان، لكننا نستخدمه من query) -->
          <input type="hidden" name="manage_token" value="{manage_token}" />
          <label>الاسم الكامل الجديد:</label>
          <input type="text" name="new_full_name" placeholder="{record.full_name || 'أدخل الاسم الجديد'}" required />
          <button type="submit">تعديل</button>
        </form>

        {editMessage && (
          <div class={editSuccess ? 'success' : 'error'}>
            {editMessage}
          </div>
        )}
      </div>
    ) : (
      <p>لا يوجد حجز متاح لهذا التوكن.</p>
    )}

  </body>
</html>
