---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/utils.ts';

const t = useTranslations(Astro.currentLocale ?? 'ar');

const pageTitle           = t('booking.title');
const fullNameLabel       = t('booking.full_name');
const fullNamePlaceholder = t('booking.full_name_placeholder');
const emailLabel          = t('booking.email');
const emailPlaceholder    = t('booking.email_placeholder');
const phoneLabel          = t('booking.phone');
const phonePlaceholder    = t('booking.phone_placeholder');
const reasonLabel         = t('booking.reason');
const reasonPlaceholder   = t('booking.reason_placeholder');
const dateLabel           = t('booking.date');
const timeLabel           = t('booking.time');
const submitButton        = t('buttons.submit');


// const selectDateFirst     = t('booking.select_date_first');
const noTimesAvailable    = t('booking.no_times_available');
const dateTriggerDefault  = t('booking.date_trigger_default');
const timeTriggerDefault  = t('booking.time_trigger_default');
---

<BaseLayout title={pageTitle}>
  <section class="booking-form">
    <div class="booking-form__container">
      <h1 class="booking-form__title">{pageTitle}</h1>

      <form id="bookingForm" class="booking-form__form">
  <div class="booking-form__group">
    <label for="full_name">{fullNameLabel} <span class="required">*</span></label>
    <input 
      type="text" 
      id="full_name" 
      name="full_name" 
      required 
      placeholder={fullNamePlaceholder} 
      maxlength="40" 
      minlength="3"
      oninvalid="
      if(this.validity.valueMissing){
      this.setCustomValidity('يجب ملء هذا الحقل');
      }
      else if(this.validity.tooShort){
      this.setCustomValidity('يجب ألا يقل الاسم عن ٣ حروف');
      }"
      oninput="this.setCustomValidity('');
      this.checkValidity();"
    />
  </div>

  <div class="booking-form__group">
    <label for="email">{emailLabel} <span class="required">*</span></label>
    <input 
      type="email" 
      id="email" 
      name="email" 
      required 
      placeholder={emailPlaceholder} 
      autocomplete="email" 
      maxlength="70"
      oninvalid="
      if(this.validity.valueMissing){
      this.setCustomValidity('يجب ملء هذا الحقل');
      }
      else if(this.validity.typeMismatch){
      this.setCustomValidity('يرجى كتابة بريد الكتروني صالح');
      }"
      oninput="this.setCustomValidity('');
      this.checkValidity();"
    />
    <div class="text_under_input">
      سيتم ارسال رسالة الى بريدك الالكتروني
    </div>
  </div>

  <div class="booking-form__group">
    <label for="phone">{phoneLabel} <span class="required">*</span></label>
    <input 
      type="tel" 
      id="phone" 
      name="phone" 
      required 
      placeholder={phonePlaceholder} 
      autocomplete="tel" 
      inputmode="numeric" 
      pattern="[0-9+]{8,20}"
      oninvalid="
      if(this.validity.valueMissing){
      this.setCustomValidity('يجب ملء هذا الحقل');
      } 
      else if(this.validity.patternMismatch){
      this.setCustomValidity('يرجى كتابة رقم هاتف صالح');
      }"
      oninput="this.setCustomValidity('');
      this.checkValidity();"
    />
  </div>

  <div class="booking-form__row date-time-row">
    <div class="booking-form__group half">
      <label for="appointment_date_display">{dateLabel} <span class="required">*</span></label>
      <div 
        class="custom-picker-trigger" 
        id="date-trigger" 
        tabindex="0" 
        role="button"
      >
        {dateTriggerDefault}
      </div>
      
      
      <div class="dropdown-menu hidden" id="date-dropdown">
        <div class="scroll-container" id="date-scroll"></div>
      </div>
    </div>

    <div class="booking-form__group half">
      <label for="appointment_time_display">{timeLabel} <span class="required">*</span></label>
      <div 
        class="custom-picker-trigger" 
        id="time-trigger" 
        tabindex="0" 
        role="button"
      >
        {timeTriggerDefault}
      </div>
      
      
      <div class="dropdown-menu hidden" id="time-dropdown">
        <div class="scroll-container" id="time-scroll"></div>
      </div>
    </div>
  </div>

  <!-- الحقل المخفي الجديد المهم -->
  <input type="hidden" id="datetime" name="datetime" />

  <div class="booking-form__group">
    <label for="reason">{reasonLabel}</label>
    <textarea 
      id="reason" 
      name="reason" 
      rows="3" 
      maxlength="55" 
      placeholder={reasonPlaceholder}
    ></textarea>
  </div>

  <div 
  id="message" 
  class="booking-form__message booking-form__message--hidden"
  ></div>

  <button type="submit" class="booking-form__submit">
    {submitButton}
  </button>
</form>
    </div>
  </section>


<script>
  // =============================================================
  // الثوابت والعناصر الأساسية
  // =============================================================
  const CREATE_APPOINTMENT_URL = `${import.meta.env.PUBLIC_SUPABASE_URL}/functions/v1/create-appointment`;
  const AVAILABILITY_URL = `${import.meta.env.PUBLIC_SUPABASE_URL}/functions/v1/check-booked-times`;

  const form = document.getElementById('bookingForm');
  const messageDiv = document.getElementById('message');

  const locale = document.documentElement.lang || 'ar';
  const isArabic = locale.startsWith('ar');

  // نصوص افتراضية متعددة اللغات
  const t = {
   // dateTriggerDefault:   isArabic ? 'اخترر التاريخ ←'      : 'Choose date ←',
   // timeTriggerDefault:   isArabic ? 'اخترر الوقت ←'        : 'Choose time ←',
    selectDateFirst:      isArabic ? 'اخترر التاريخ أولاً'  : 'Select date first',
    noTimesAvailable:     isArabic ? 'لا توجد موااعيد متاحة' : 'No times available',
    noAppointmentsDays:   isArabic ? 'لا توجد موااعيد متاحة في الفترة القادمة' : 'No appointments available in the upcoming days',
    fetchError:           isArabic ? 'خطأ في جلب الموااعيد' : 'Failed to load appointments',
    sending:              isArabic ? 'جااري الإرسال...'     : 'Submitting...',
    missingDateTime:      isArabic ? 'يرجى اختياار التاريخ والوقت' : 'Please select date and time',
    loadingAppointments:  isArabic ? 'جاري تحميل الموااعيد...' : 'Loading appointments...',
// ==========================
// success messages
// ==========================

success_APPOINTMENT_CREATED: isArabic
  ? 'تم حجز الموعد بنجااح'
  : 'Appointment booked successfully',

success_APPOINTMENT_RESCHEDULED: isArabic
  ? 'تمت إعادة جدولة الموعد بنجااح'
  : 'Appointment rescheduled successfully',

success_APPOINTMENT_CANCELLED: isArabic
  ? 'تم إلغاء الموعد بنجااح'
  : 'Appointment cancelled successfully',

success_GENERIC_SUCCESS: isArabic
  ? 'تمت العملية بنجااح'
  : 'Operation completed successfully',

// ==========================
// error messages
// ==========================

error_TIME_ALREADY_BOOKED: isArabic
  ? 'هذا الموعد محجوز بالفعل'
  : 'This time slot is already booked',

error_TIME_NOT_AVAILABLE: isArabic
  ? 'هذا الوقت غير متاح'
  : 'This time is not available',

error_PAST_DATE: isArabic
  ? 'لا يمكن حجز موعد في الماضي'
  : 'Cannot book a past date',

error_INVALID_EMAIL: isArabic
  ? 'البريد الإلكتروني غير صالح'
  : 'Invalid email address',

error_UNKNOWN_ERROR: isArabic
  ? 'حدث خطأ غير متوقع'
  : 'Unexpected error occurred',
    };

  let selectedDate = '';
  let selectedTime = '';
  let dateOriginalText = '';
  let timeOriginalText = '';

  // =============================================================
  // دوال مساعدة للرسائل والإعادة التعيين
  // =============================================================
  function showMessage(text, type = 'info') {
    messageDiv.classList.remove('booking-form__message--hidden', 'success', 'error');
    messageDiv.classList.add(type === 'success' ? 'success' : 'error');
    messageDiv.textContent = text;
  }

  function hideMessage() {
    messageDiv.classList.add('booking-form__message--hidden');
  }

  function resetPickers() {
    selectedDate = '';
    selectedTime = '';
    document.getElementById('date-trigger').textContent = t.dateTriggerDefault;
    document.getElementById('time-trigger').textContent  = t.timeTriggerDefault;
    document.getElementById('datetime').value = '';
    document.querySelectorAll('.scroll-item.selected').forEach(el => el.classList.remove('selected'));
    document.getElementById('date-dropdown')?.classList.add('hidden');
    document.getElementById('time-dropdown')?.classList.add('hidden');
  }

  // =============================================================
  // إرسال النموذج إلى Edge Function create-appointment
  // =============================================================
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    hideMessage();

    if (!selectedDate || !selectedTime) {
      showMessage(t.missingDateTime, 'error');
      return;
    }

    const payload = {
      full_name: form.full_name?.value?.trim() || '',
      email:     form.email?.value?.trim()     || '',
      phone:     form.phone?.value?.trim()     || '',
      reason:    form.reason?.value?.trim()    || '',
      datetime:  `${selectedDate}T${selectedTime}:00`
    };

    showMessage(t.sending, 'info');

    try {
      const res = await fetch(CREATE_APPOINTMENT_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      const result = await res.json();

      if (res.ok && result.success) {

      const code = result.success_code || 'GENERIC_SUCCESS';

      showMessage(
       t[`success_${code}`], 'success');
      form.reset();
      resetPickers();
      } else {
      const code = result.error_code || 'UNKNOWN_ERROR';

      showMessage( t[`error_${code}`],'error');
      }

    } catch (err) {
      console.error('خطأ أثناء إرسال الحجز:', err);
      showMessage(
      t.error_UNKNOWN_ERROR,'error');
       }
   });

  // =============================================================
  // توليد قائمة التواريخ المتاحة
  // =============================================================
  const dateTrigger  = document.getElementById('date-trigger');
  const dateDropdown = document.getElementById('date-dropdown');
  const dateScroll   = document.getElementById('date-scroll');

  async function generateDates() {
    dateScroll.innerHTML = `<div class="scroll-item disabled">${t.loadingAppointments}</div>`;

    try {
      const res = await fetch(AVAILABILITY_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          query_type: "available_dates_next_days",
          days: 15
        })
      });

      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      const { available_dates = [] } = await res.json();

      dateScroll.innerHTML = '';

      if (available_dates.length === 0) {
        dateScroll.innerHTML = `<div class="scroll-item disabled">${t.noAppointmentsDays}</div>`;
        return;
      }

      available_dates.forEach(dateStr => {
        const d = new Date(dateStr);
        const dayName   = d.toLocaleDateString(locale, { weekday: 'long' });
        const monthName = d.toLocaleDateString(locale, { month: 'long' });
        const dayNum    = d.getDate().toString().padStart(2, '0');
        const year      = d.getFullYear();

        const display = isArabic
          ? `${dayName} ${dayNum} ${monthName} ${year}`
          : `${dayName}, ${monthName} ${dayNum}, ${year}`;

        const item = document.createElement('div');
        item.className = 'scroll-item';
        item.dataset.value = dateStr;
        item.textContent = display;
        dateScroll.appendChild(item);
      });

      // إعادة تمييز التاريخ المختار إن وُجد
      if (selectedDate) {
        const el = dateScroll.querySelector(`[data-value="${selectedDate}"]`);
        if (el) {
          dateScroll.querySelectorAll('.scroll-item').forEach(i => i.classList.remove('selected'));
          el.classList.add('selected');
          el.scrollIntoView({ block: 'center', behavior: 'smooth' });
        }
      }
    } catch (err) {
      console.error('خطأ تحميل التواريخ:', err);
      dateScroll.innerHTML = `<div class="scroll-item disabled">${t.fetchError}</div>`;;
    }
  }

  dateTrigger.addEventListener('click', async (e) => {
  e.stopPropagation();
  const willOpen = dateDropdown.classList.contains('hidden');
  document.getElementById('time-dropdown')?.classList.add('hidden');

  if (!willOpen) {
    dateDropdown.classList.add('hidden');

    if (dateOriginalText) {
      dateTrigger.textContent = dateOriginalText;
    }

  } else {

    dateOriginalText = dateTrigger.textContent;
    dateTrigger.textContent = t.loadingAppointments;

    await generateDates();

    if (dateOriginalText) {
      dateTrigger.textContent = dateOriginalText;
    }

    dateDropdown.classList.remove('hidden');

/* scroll إلى التاريخ المختار */
if (selectedDate) {

  setTimeout(() => {

    const el = dateScroll.querySelector(`[data-value="${selectedDate}"]`);

    if (el) {
      el.scrollIntoView({
        behavior: 'auto',
        block: 'center'
      });
    }

  }, 10);

}
  }
});

  dateScroll.addEventListener('click', (e) => {

const item =
e.target.closest('.scroll-item');

if (!item ||
item.classList.contains('disabled'))
return;

dateScroll
.querySelectorAll('.scroll-item')
.forEach(el => el.classList.remove('selected'));

item.classList.add('selected');

dateTrigger.textContent =
item.textContent;

selectedDate = item.dataset.value;

dateDropdown.classList.add('hidden');

/* reset الوقت عند تغيير التاريخ */
selectedTime = '';
document.getElementById('time-trigger').textContent =
t.timeTriggerDefault;

generateTimes();

});

  // =============================================================
  // توليد قائمة الأوقات المتاحة
  // =============================================================
  const timeTrigger  = document.getElementById('time-trigger');
  const timeDropdown = document.getElementById('time-dropdown');
  const timeScroll   = document.getElementById('time-scroll');

  async function generateTimes() {
    timeScroll.innerHTML = `<div class="scroll-item disabled">${t.loadingAppointments}</div>`;

    if (!selectedDate) {
      timeScroll.innerHTML = `<div class="scroll-item disabled">${t.selectDateFirst}</div>`;
      return;
    }

    try {
      const res = await fetch(AVAILABILITY_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          query_type: "available_times_for_date",
          date: selectedDate
        })
      });

      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      const { available_times = [] } = await res.json();

      timeScroll.innerHTML = '';

      if (available_times.length === 0) {
        timeScroll.innerHTML = `<div class="scroll-item disabled">${t.noTimesAvailable}</div>`;
        return;
      }

      available_times.forEach(time24 => {
        const [hourStr, minuteStr] = time24.split(':');
        const hour   = parseInt(hourStr, 10);
        const minute = parseInt(minuteStr, 10);

        if (isNaN(hour) || isNaN(minute)) return;

        let display;
        if (isArabic) {
          if (hour === 12) {
            display = `12:${minute.toString().padStart(2, '0')} ظهرًا`;
          } else if (hour > 12) {
            display = `${(hour - 12).toString().padStart(2, '0')}:${minute.toString().padStart(2, '0')} مساءً`;
          } else {
            display = `${hour.toString().padStart(2, '0')}:${minute.toString().padStart(2, '0')} صباحًا`;
          }
        } else {
          const h = (hour % 12) || 12;
          const period = hour < 12 ? 'AM' : 'PM';
          display = `${h}:${minute.toString().padStart(2, '0')} ${period}`;
        }

        const item = document.createElement('div');
        item.className = 'scroll-item';
        item.dataset.value = time24;
        item.textContent = display;
        timeScroll.appendChild(item);
      });

      // إعادة تمييز الوقت المختار إن وُجد
      if (selectedTime) {
        const el = timeScroll.querySelector(`[data-value="${selectedTime}"]`);
        if (el) {
          timeScroll.querySelectorAll('.scroll-item').forEach(i => i.classList.remove('selected'));
          el.classList.add('selected');
          el.scrollIntoView({ block: 'center', behavior: 'smooth' });
        }
      }
    } catch (err) {
      console.error('خطأ تحميل الأوقات:', err);
      timeScroll.innerHTML = `<div class="scroll-item disabled">${t.fetchError}</div>`;
    }
  }

  timeTrigger.addEventListener('click', async (e) => {
  e.stopPropagation();
  const willOpen = timeDropdown.classList.contains('hidden');
  document.getElementById('date-dropdown')?.classList.add('hidden');

  if (!willOpen) {
    timeDropdown.classList.add('hidden');

    if (timeOriginalText) {
      timeTrigger.textContent = timeOriginalText;
    }

  } else {

    timeOriginalText = timeTrigger.textContent;
    timeTrigger.textContent = t.loadingAppointments;

    await generateTimes();

    if (timeOriginalText) {
      timeTrigger.textContent = timeOriginalText;
    }

timeDropdown.classList.remove('hidden');

/* scroll إلى الوقت المختار */
if (selectedTime) {

  setTimeout(() => {

    const el = timeScroll.querySelector(`[data-value="${selectedTime}"]`);

    if (el) {
      el.scrollIntoView({
        behavior: 'auto',
        block: 'center'
      });
    }

  }, 10);

}

  }
});

  timeScroll.addEventListener('click', (e) => {
    const item = e.target.closest('.scroll-item');
    if (!item || item.classList.contains('disabled')) return;

    timeScroll.querySelectorAll('.scroll-item').forEach(el => el.classList.remove('selected'));
    item.classList.add('selected');

    timeTrigger.textContent = item.textContent;
    selectedTime = item.dataset.value;
    timeDropdown.classList.add('hidden');
  });

  // =============================================================
  // إغلاق القوائم عند النقر خارجها
  // =============================================================
  document.addEventListener('click', (e) => {

  if (!dateTrigger.contains(e.target) && !dateDropdown.contains(e.target)) {
    dateDropdown.classList.add('hidden');

    // إعادة النص فقط إذا كانت رسالة التحميل ظاهرة
    if (dateTrigger.textContent === t.loadingAppointments) {
      if (selectedDate) {
        const selectedItem = dateScroll.querySelector(`[data-value="${selectedDate}"]`);
        if (selectedItem) {
          dateTrigger.textContent = selectedItem.textContent;
        }
      } else {
        dateTrigger.textContent = t.dateTriggerDefault;
      }
    }
  }

  if (!timeTrigger.contains(e.target) && !timeDropdown.contains(e.target)) {
    timeDropdown.classList.add('hidden');

    // إعادة النص فقط إذا كانت رسالة التحميل ظاهرة
    if (timeTrigger.textContent === t.loadingAppointments) {
      if (selectedTime) {
        const selectedItem = timeScroll.querySelector(`[data-value="${selectedTime}"]`);
        if (selectedItem) {
          timeTrigger.textContent = selectedItem.textContent;
        }
      } else {
        timeTrigger.textContent = t.timeTriggerDefault;
      }
    }
  }

});

</script>

  </BaseLayout>
