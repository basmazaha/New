---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/utils';

const t = useTranslations(Astro.currentLocale ?? 'ar');

const pageTitle           = t('booking.title');
const fullNameLabel       = t('booking.full_name');
const fullNamePlaceholder = t('booking.full_name_placeholder');
const emailLabel          = t('booking.email');
const emailPlaceholder    = t('booking.email_placeholder');
const phoneLabel          = t('booking.phone');
const phonePlaceholder    = t('booking.phone_placeholder');
const reasonLabel         = t('booking.reason');
const reasonPlaceholder   = t('booking.reason_placeholder');
const dateLabel           = t('booking.date');
const timeLabel           = t('booking.time');
const submitButton        = t('buttons.submit');

const selectDateFirst     = t('booking.select_date_first');
const noTimesAvailable    = t('booking.no_times_available');
const dateTriggerDefault  = t('booking.date_trigger_default');
const timeTriggerDefault  = t('booking.time_trigger_default');

const loadingAppointments = t('booking.loading_appointments') || 'Loading appointments...';
const missingDateTime     = t('booking.missing_datetime') || 'Please select date and time';
const sendingText         = t('booking.sending') || 'Submitting...';
const fetchErrorText      = t('booking.fetch_error') || 'Failed to load appointments';
---

<BaseLayout title={pageTitle}>

<section class="booking-form">
<div class="booking-form__container">

<h1 class="booking-form__title">{pageTitle}</h1>

<form id="bookingForm" class="booking-form__form">

<div class="booking-form__group">
<label for="full_name">{fullNameLabel} <span class="required">*</span></label>

<input
type="text"
id="full_name"
name="full_name"
required
placeholder={fullNamePlaceholder}
maxlength="40"
minlength="3"
/>

</div>

<div class="booking-form__group">

<label for="email">{emailLabel} <span class="required">*</span></label>

<input
type="email"
id="email"
name="email"
required
placeholder={emailPlaceholder}
autocomplete="email"
maxlength="70"
/>

</div>

<div class="booking-form__group">

<label for="phone">{phoneLabel} <span class="required">*</span></label>

<input
type="tel"
id="phone"
name="phone"
required
placeholder={phonePlaceholder}
autocomplete="tel"
inputmode="numeric"
pattern="[0-9+]{8,20}"
/>

</div>

<div class="booking-form__row date-time-row">

<div class="booking-form__group half">

<label>{dateLabel} <span class="required">*</span></label>

<div
class="custom-picker-trigger"
id="date-trigger"
tabindex="0"
role="button"
>
{dateTriggerDefault}
</div>

<div class="dropdown-menu hidden" id="date-dropdown">
<div class="scroll-container" id="date-scroll"></div>
</div>

</div>

<div class="booking-form__group half">

<label>{timeLabel} <span class="required">*</span></label>

<div
class="custom-picker-trigger"
id="time-trigger"
tabindex="0"
role="button"
>
{timeTriggerDefault}
</div>

<div class="dropdown-menu hidden" id="time-dropdown">
<div class="scroll-container" id="time-scroll"></div>
</div>

</div>

</div>

<input type="hidden" id="datetime" name="datetime"/>

<div class="booking-form__group">

<label for="reason">{reasonLabel}</label>

<textarea
id="reason"
name="reason"
rows="3"
maxlength="55"
placeholder={reasonPlaceholder}
></textarea>

</div>

<div id="message"
class="booking-form__message booking-form__message--hidden"></div>

<button type="submit" class="booking-form__submit">
{submitButton}
</button>

</form>

</div>
</section>

<script define:vars={{
dateTriggerDefault,
timeTriggerDefault,
selectDateFirst,
noTimesAvailable,
loadingAppointments,
missingDateTime,
sendingText,
fetchErrorText
}}>

const CREATE_APPOINTMENT_URL = `${import.meta.env.PUBLIC_SUPABASE_URL}/functions/v1/create-appointment`;
const AVAILABILITY_URL = `${import.meta.env.PUBLIC_SUPABASE_URL}/functions/v1/check-booked-times`;

const form = document.getElementById('bookingForm');
const messageDiv = document.getElementById('message');

let selectedDate = '';
let selectedTime = '';

function showMessage(text,type='info'){

messageDiv.classList.remove('booking-form__message--hidden','success','error');

if(type==='success'){
messageDiv.classList.add('success');
}else{
messageDiv.classList.add('error');
}

messageDiv.textContent=text;

}

function hideMessage(){
messageDiv.classList.add('booking-form__message--hidden');
}

function resetPickers(){

selectedDate='';
selectedTime='';

document.getElementById('date-trigger').textContent=dateTriggerDefault;
document.getElementById('time-trigger').textContent=timeTriggerDefault;

document.getElementById('datetime').value='';

}

form.addEventListener('submit',async(e)=>{

e.preventDefault();

hideMessage();

if(!selectedDate || !selectedTime){

showMessage(missingDateTime,'error');
return;

}

const payload={

full_name:form.full_name.value.trim(),
email:form.email.value.trim(),
phone:form.phone.value.trim(),
reason:form.reason.value.trim(),
datetime:`${selectedDate}T${selectedTime}:00`

};

showMessage(sendingText,'info');

try{

const res=await fetch(CREATE_APPOINTMENT_URL,{
method:'POST',
headers:{'Content-Type':'application/json'},
body:JSON.stringify(payload)
});

const result=await res.json();

if(res.ok && result.success){

showMessage(result.message || 'Success','success');

form.reset();
resetPickers();

}else{

showMessage(result.message || 'Error','error');

}

}catch(err){

console.error(err);
showMessage('Unexpected error','error');

}

});

const dateTrigger=document.getElementById('date-trigger');
const dateDropdown=document.getElementById('date-dropdown');
const dateScroll=document.getElementById('date-scroll');

async function generateDates(){

dateScroll.innerHTML=`<div class="scroll-item disabled">${loadingAppointments}</div>`;

try{

const res=await fetch(AVAILABILITY_URL,{
method:'POST',
headers:{'Content-Type':'application/json'},
body:JSON.stringify({
query_type:'available_dates_next_days',
days:15
})
});

const data=await res.json();

dateScroll.innerHTML='';

if(!data.available_dates.length){

dateScroll.innerHTML=`<div class="scroll-item disabled">${noTimesAvailable}</div>`;
return;

}

data.available_dates.forEach(date=>{

const item=document.createElement('div');

item.className='scroll-item';
item.dataset.value=date;
item.textContent=date;

dateScroll.appendChild(item);

});

}catch(err){

console.error(err);
dateScroll.innerHTML=`<div class="scroll-item disabled">${fetchErrorText}</div>`;

}

}

dateTrigger.addEventListener('click',async(e)=>{

e.stopPropagation();

const willOpen=dateDropdown.classList.contains('hidden');

if(!willOpen){

dateDropdown.classList.add('hidden');

}else{

await generateDates();
dateDropdown.classList.remove('hidden');

}

});

dateScroll.addEventListener('click',(e)=>{

const item=e.target.closest('.scroll-item');

if(!item)return;

dateScroll.querySelectorAll('.scroll-item').forEach(el=>el.classList.remove('selected'));

item.classList.add('selected');

selectedDate=item.dataset.value;

dateTrigger.textContent=item.textContent;

dateDropdown.classList.add('hidden');

});

const timeTrigger=document.getElementById('time-trigger');
const timeDropdown=document.getElementById('time-dropdown');
const timeScroll=document.getElementById('time-scroll');

async function generateTimes(){

timeScroll.innerHTML=`<div class="scroll-item disabled">${loadingAppointments}</div>`;

if(!selectedDate){

timeScroll.innerHTML=`<div class="scroll-item disabled">${selectDateFirst}</div>`;
return;

}

try{

const res=await fetch(AVAILABILITY_URL,{
method:'POST',
headers:{'Content-Type':'application/json'},
body:JSON.stringify({
query_type:'available_times_for_date',
date:selectedDate
})
});

const data=await res.json();

timeScroll.innerHTML='';

if(!data.available_times.length){

timeScroll.innerHTML=`<div class="scroll-item disabled">${noTimesAvailable}</div>`;
return;

}

data.available_times.forEach(time=>{

const item=document.createElement('div');

item.className='scroll-item';
item.dataset.value=time;
item.textContent=time;

timeScroll.appendChild(item);

});

}catch(err){

console.error(err);
timeScroll.innerHTML=`<div class="scroll-item disabled">${fetchErrorText}</div>`;

}

}

timeTrigger.addEventListener('click',async(e)=>{

e.stopPropagation();

const willOpen=timeDropdown.classList.contains('hidden');

if(!willOpen){

timeDropdown.classList.add('hidden');

}else{

await generateTimes();
timeDropdown.classList.remove('hidden');

}

});

timeScroll.addEventListener('click',(e)=>{

const item=e.target.closest('.scroll-item');

if(!item)return;

timeScroll.querySelectorAll('.scroll-item').forEach(el=>el.classList.remove('selected'));

item.classList.add('selected');

selectedTime=item.dataset.value;

timeTrigger.textContent=item.textContent;

timeDropdown.classList.add('hidden');

});

document.addEventListener('click',(e)=>{

if(!dateTrigger.contains(e.target) && !dateDropdown.contains(e.target)){
dateDropdown.classList.add('hidden');
}

if(!timeTrigger.contains(e.target) && !timeDropdown.contains(e.target)){
timeDropdown.classList.add('hidden');
}

});

</script>

</BaseLayout>
